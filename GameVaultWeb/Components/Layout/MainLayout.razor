@inherits LayoutComponentBase
@using GameVaultWeb.Services
@inject UserState User

<div class="page">
    <!-- Top Header Bar with Account/Cart Icons -->
    <header class="top-header">
        <div class="container-fluid d-flex justify-content-between align-items-center">
            <a href="/" class="site-logo">
                <span class="bi bi-controller me-2"></span>
                <strong>GameVault</strong>
            </a>
            
            <!-- Search Bar (REQ-52) -->
            <div class="header-search flex-grow-1 mx-4">
                <SearchBar/>
            </div>
            
            <!-- User Actions -->
            <div class="header-actions d-flex align-items-center gap-3">
                @if (User.IsLoggedIn)
                {
                    <a href="/cart" class="header-icon" title="Shopping Cart">
                        <i class="bi bi-cart3"></i>
                        <span class="badge bg-danger cart-badge">0</span>
                    </a>
                    <a href="/account" class="header-icon" title="Account">
                        <i class="bi bi-person-circle"></i>
                        <span class="user-name ms-2">@(User.Username ?? "User")</span>
                    </a>
                }
                else
                {
                    <a href="/login" class="btn btn-primary">
                        <i class="bi bi-box-arrow-in-right me-1"></i>
                        Login
                    </a>
                }
            </div>
        </div>
    </header>

    <div class="page-content">
        <div class="sidebar">
            <NavMenu />
        </div>
        <main>
            <article class="content px-4">
                @Body
            </article>
        </main>
    </div>

</div>
