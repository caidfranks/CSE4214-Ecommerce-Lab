@page "/account"
@rendermode InteractiveServer
@using GameVaultWeb.Services
@inject UserState User
@inject NavigationManager Nav

<PageTitle>Account - GameVault</PageTitle>

@if (!User.IsLoggedIn)
{
    <div class="container mt-5">
        <div class="alert alert-warning">
            <h4>Not Logged In</h4>
            <p>You need to log in to view your account. <a href="/login" class="alert-link">Go to Login</a></p>
        </div>
    </div>
}
else
{
    <div class="container mt-4">
        <h2>Account Information</h2>

        <!-- Account Tabs -->
        <ul class="nav nav-tabs mt-4" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link @(activeTab == "info" ? "active" : "")"
                        @onclick='() => activeTab = "info"'>
                    Account Info
                </button>
            </li>
            @if (User.Role == "Customer")
            {
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(activeTab == "orders" ? "active" : "")"
                            @onclick='() => activeTab = "orders"'>
                        Order History
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(activeTab == "payment" ? "active" : "")"
                            @onclick='() => activeTab = "payment"'>
                        Payment Methods
                    </button>
                </li>
            }
            @if (User.Role == "Vendor")
            {
                <li class="nav-item" role="presentation">
                    <button class="nav-link @(activeTab == "banking" ? "active" : "")"
                            @onclick='() => activeTab = "banking"'>
                        Banking Info
                    </button>
                </li>
            }
        </ul>

        <!-- Tab Content -->
        <div class="tab-content mt-4">
            <!-- Account Information Tab -->
            @if (activeTab == "info")
            {
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title mb-4">Personal Information</h4>

                        <!-- Display Name (Vendors only - REQ-96) -->
                        @if (User.Role == "Vendor")
                        {
                            <div class="info-section mb-4">
                                <label class="form-label fw-bold">Display Name</label>
                                @if (!editingDisplayName)
                                {
                                    <div class="d-flex align-items-center">
                                        <p class="mb-0 me-3">@displayName</p>
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => editingDisplayName = true">
                                            Edit
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <div class="input-group mb-2">
                                        <input type="text" class="form-control" @bind="newDisplayName" />
                                        <button class="btn btn-success" @onclick="UpdateDisplayName">Save</button>
                                        <button class="btn btn-secondary" @onclick="() => editingDisplayName = false">Cancel</button>
                                    </div>
                                }
                            </div>
                        }

                        <!-- Username -->
                        <div class="info-section mb-4">
                            <label class="form-label fw-bold">Username</label>
                            <p class="mb-0">@(User.Username ?? "Guest")</p>
                        </div>

                        <!-- Email (REQ-93, REQ-94) -->
                        <div class="info-section mb-4">
                            <label class="form-label fw-bold">Email</label>
                            @if (!editingEmail)
                            {
                                <div class="d-flex align-items-center">
                                    <p class="mb-0 me-3">@email</p>
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => editingEmail = true">
                                        Update Email
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="mt-2">
                                    <input type="email" class="form-control mb-2" placeholder="New Email" @bind="newEmail" />
                                    <input type="password" class="form-control mb-2" placeholder="Enter Password to Confirm" @bind="confirmPassword" />
                                    <button class="btn btn-success me-2" @onclick="UpdateEmail">Update</button>
                                    <button class="btn btn-secondary" @onclick="() => editingEmail = false">Cancel</button>
                                    @if (!string.IsNullOrEmpty(emailMessage))
                                    {
                                        <div class="alert alert-info mt-2">@emailMessage</div>
                                    }
                                </div>
                            }
                        </div>

                        <!-- Password (REQ-95) -->
                        <div class="info-section mb-4">
                            <label class="form-label fw-bold">Password</label>
                            @if (!editingPassword)
                            {
                                <div class="d-flex align-items-center">
                                    <p class="mb-0 me-3">••••••••</p>
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => editingPassword = true">
                                        Update Password
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="mt-2">
                                    <input type="password" class="form-control mb-2" placeholder="Current Password" @bind="currentPassword" />
                                    <input type="password" class="form-control mb-2" placeholder="New Password" @bind="newPassword" />
                                    <input type="password" class="form-control mb-2" placeholder="Confirm New Password" @bind="confirmNewPassword" />
                                    <button class="btn btn-success me-2" @onclick="UpdatePassword">Update</button>
                                    <button class="btn btn-secondary" @onclick="() => editingPassword = false">Cancel</button>
                                    @if (!string.IsNullOrEmpty(passwordMessage))
                                    {
                                        <div class="alert alert-info mt-2">@passwordMessage</div>
                                    }
                                </div>
                            }
                        </div>

                        <!-- Role -->
                        <div class="info-section mb-4">
                            <label class="form-label fw-bold">Account Type</label>
                            <p class="mb-0">
                                <span class="badge bg-primary">@User.Role</span>
                            </p>
                        </div>

                        <!-- Logout Button (REQ-15) -->
                        <div class="mt-4 pt-3 border-top">
                            <button class="btn btn-danger" @onclick="Logout">Log Out</button>
                        </div>
                    </div>
                </div>
            }

            <!-- Order History Tab (Customer only - REQ-83-86) -->
            @if (activeTab == "orders" && User.Role == "Customer")
            {
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title mb-4">Order History</h4>

                        @if (orders.Count == 0)
                        {
                            <p class="text-muted">You haven't placed any orders yet.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Order ID</th>
                                            <th>Date</th>
                                            <th>Status</th>
                                            <th>Total</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var order in orders)
                                        {
                                            <tr>
                                                <td>#@order.Id</td>
                                                <td>@order.Date.ToString("MM/dd/yyyy")</td>
                                                <td>
                                                    <span class="badge @GetStatusBadgeClass(order.Status)">
                                                        @order.Status
                                                    </span>
                                                </td>
                                                <td>$@order.Total.ToString("F2")</td>
                                                <td>
                                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => ViewOrderDetails(order.Id)">
                                                        View Details
                                                    </button>
                                                    @if (order.Status == "Completed")
                                                    {
                                                        <button class="btn btn-sm btn-outline-warning ms-2" @onclick="() => StartReturn(order.Id)">
                                                            Return
                                                        </button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Payment Methods Tab (Customer only) -->
            @if (activeTab == "payment" && User.Role == "Customer")
            {
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title mb-4">Saved Payment Methods</h4>

                        @if (paymentMethods.Count == 0)
                        {
                            <p class="text-muted">No saved payment methods.</p>
                        }
                        else
                        {
                            @foreach (var payment in paymentMethods)
                            {
                                <div class="card mb-3">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h6 class="mb-1">@payment.Type</h6>
                                                <p class="mb-0 text-muted">•••• •••• •••• @payment.LastFour</p>
                                                <small class="text-muted">Expires: @payment.ExpiryDate</small>
                                            </div>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemovePaymentMethod(payment.Id)">
                                                Remove
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        }

                        <button class="btn btn-primary mt-3" @onclick="AddPaymentMethod">
                            Add Payment Method
                        </button>
                    </div>
                </div>
            }

            <!-- Banking Info Tab (Vendor only - REQ-174-178) -->
            @if (activeTab == "banking" && User.Role == "Vendor")
            {
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title mb-4">Banking Information</h4>

                        @if (string.IsNullOrEmpty(bankingInfo))
                        {
                            <p class="text-muted mb-3">No banking information on file.</p>
                            <button class="btn btn-primary" @onclick="() => editingBanking = true">
                                Add Banking Info
                            </button>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label class="form-label fw-bold">Account Number</label>
                                <p class="mb-0">•••• •••• @bankingInfo</p>
                            </div>
                            <button class="btn btn-primary" @onclick="() => editingBanking = true">
                                Update Banking Info
                            </button>
                        }

                        @if (editingBanking)
                        {
                            <div class="mt-4 p-3 border rounded">
                                <h5>Update Banking Information</h5>
                                <input type="password" class="form-control mb-2" placeholder="Enter Password" @bind="bankingPassword" />
                                <input type="text" class="form-control mb-2" placeholder="Routing Number" @bind="routingNumber" />
                                <input type="text" class="form-control mb-2" placeholder="Account Number" @bind="accountNumber" />
                                <button class="btn btn-success me-2" @onclick="UpdateBankingInfo">Save</button>
                                <button class="btn btn-secondary" @onclick="() => editingBanking = false">Cancel</button>
                                @if (!string.IsNullOrEmpty(bankingMessage))
                                {
                                    <div class="alert alert-info mt-2">@bankingMessage</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

@code {
    private string activeTab = "info";

    // Account Info
    private string email = "user@example.com";
    private string displayName = "My Game Store";
    private bool editingEmail = false;
    private bool editingPassword = false;
    private bool editingDisplayName = false;
    private bool editingBanking = false;

    private string newEmail = "";
    private string confirmPassword = "";
    private string currentPassword = "";
    private string newPassword = "";
    private string confirmNewPassword = "";
    private string newDisplayName = "";
    private string emailMessage = "";
    private string passwordMessage = "";

    // Banking Info (Vendor)
    private string bankingInfo = ""; // Last 4 digits
    private string routingNumber = "";
    private string accountNumber = "";
    private string bankingPassword = "";
    private string bankingMessage = "";

    // Orders (Customer)
    private List<Order> orders = new();

    // Payment Methods (Customer)
    private List<PaymentMethod> paymentMethods = new();

    protected override void OnInitialized()
    {
        // Load mock data
        if (User.Role == "Customer")
        {
            LoadMockOrders();
            LoadMockPaymentMethods();
        }
        else if (User.Role == "Vendor")
        {
            displayName = User.Username ?? "Vendor";
            newDisplayName = displayName;
        }
    }

    private void LoadMockOrders()
    {
        orders = new List<Order>
        {
            new Order { Id = 1001, Date = DateTime.Now.AddDays(-5), Status = "Completed", Total = 129.97m },
            new Order { Id = 1002, Date = DateTime.Now.AddDays(-12), Status = "Shipped", Total = 59.99m },
            new Order { Id = 1003, Date = DateTime.Now.AddDays(-20), Status = "Completed", Total = 89.98m },
        };
    }

    private void LoadMockPaymentMethods()
    {
        paymentMethods = new List<PaymentMethod>
        {
            new PaymentMethod { Id = 1, Type = "Visa", LastFour = "4242", ExpiryDate = "12/25" },
            new PaymentMethod { Id = 2, Type = "Mastercard", LastFour = "8888", ExpiryDate = "08/26" },
        };
    }

    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Completed" => "bg-success",
            "Shipped" => "bg-info",
            "Pending" => "bg-warning",
            "Cancelled" => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private void UpdateEmail()
    {
        // TODO: Validate password and update email in database
        if (string.IsNullOrWhiteSpace(newEmail) || string.IsNullOrWhiteSpace(confirmPassword))
        {
            emailMessage = "Please fill in all fields.";
            return;
        }

        email = newEmail;
        emailMessage = "Email updated successfully!";
        editingEmail = false;
        newEmail = "";
        confirmPassword = "";
    }

    private void UpdatePassword()
    {
        // TODO: Validate current password and update in database (REQ-99-101)
        if (string.IsNullOrWhiteSpace(currentPassword) || string.IsNullOrWhiteSpace(newPassword) || string.IsNullOrWhiteSpace(confirmNewPassword))
        {
            passwordMessage = "Please fill in all fields.";
            return;
        }

        if (newPassword != confirmNewPassword)
        {
            passwordMessage = "New passwords do not match.";
            return;
        }

        passwordMessage = "Password updated successfully!";
        editingPassword = false;
        currentPassword = "";
        newPassword = "";
        confirmNewPassword = "";
    }

    private void UpdateDisplayName()
    {
        // TODO: Update in database (REQ-97)
        if (string.IsNullOrWhiteSpace(newDisplayName))
        {
            return;
        }

        displayName = newDisplayName;
        editingDisplayName = false;
    }

    private void UpdateBankingInfo()
    {
        // TODO: Validate password and update in database (REQ-176-177)
        if (string.IsNullOrWhiteSpace(bankingPassword) || string.IsNullOrWhiteSpace(routingNumber) || string.IsNullOrWhiteSpace(accountNumber))
        {
            bankingMessage = "Please fill in all fields.";
            return;
        }

        // Store only last 4 digits
        bankingInfo = accountNumber.Substring(Math.Max(0, accountNumber.Length - 4));
        bankingMessage = "Banking information updated successfully!";
        editingBanking = false;
        bankingPassword = "";
        routingNumber = "";
        accountNumber = "";
    }

    private void ViewOrderDetails(int orderId)
    {
        // TODO: Navigate to order details page
        Nav.NavigateTo($"/order/{orderId}");
    }

    private void StartReturn(int orderId)
    {
        // TODO: Navigate to return page (REQ-87-91)
        Nav.NavigateTo($"/return/{orderId}");
    }

    private void AddPaymentMethod()
    {
        // TODO: Navigate to add payment method page
        Nav.NavigateTo("/payment/add");
    }

    private void RemovePaymentMethod(int paymentId)
    {
        // TODO: Confirm and remove from database
        paymentMethods.RemoveAll(p => p.Id == paymentId);
    }

    private void Logout()
    {
        // REQ-16, REQ-17
        User.IsLoggedIn = false;
        User.Username = null;
        User.Role = "Customer";
        Nav.NavigateTo("/login", forceLoad: true);
    }

    // Models
    public class Order
    {
        public int Id { get; set; }
        public DateTime Date { get; set; }
        public string Status { get; set; } = "";
        public decimal Total { get; set; }
    }

    public class PaymentMethod
    {
        public int Id { get; set; }
        public string Type { get; set; } = "";
        public string LastFour { get; set; } = "";
        public string ExpiryDate { get; set; } = "";
    }
}